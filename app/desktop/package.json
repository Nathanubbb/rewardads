{
  "name": "rewardads",
  "version": "0.1.0",
  "author": "RewardADs team",
  "description": "RewardADs",
  "main": "build/electron.js",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.7.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "package": "electron-builder"
  },
  "build": {
    "appId": "it.nathanub.rewardads",
    "win": {
      "target": "nsis",
      "icon": "assets/icons/app-icon.ico"
    },
    "mac": {
      "icon": "assets/icons/app-icon.icns"
    },
    "linux": {
      "icon": "assets/icons/app-icon.png",
      "target": "deb",
      "category": "Utility",
      "maintainer": "RewardADs team"
    }
  },
  "homepage": "https://rewardads.it",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}
